{
  "info": {
    "name": "Dar+ API",
    "description": "Complete API collection for Dar+ — Structured Real Estate Platform\nBase URL: http://localhost:8000/api\nAuth: Bearer token in Authorization header",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Seller\",\n  \"email\": \"ahmed@darplus.ma\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"role\": \"seller\",\n  \"phone\": \"0600000001\",\n  \"city\": \"Casablanca\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@darplus.ma\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Me (Current User)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Users & Profile",
      "item": [
        {
          "name": "Get Public Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/1",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/profile",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ahmed Updated\",\n  \"phone\": \"0612345678\",\n  \"city\": \"Marrakech\",\n  \"bio\": \"Agent immobilier depuis 5 ans.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Upload Avatar",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/profile/avatar",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "avatar", "type": "file", "src": "" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Categories & Blueprints",
      "item": [
        {
          "name": "List All Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Get Category with Blueprint",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/apartment",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Get Blueprint Only",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/apartment/blueprint",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "Explorer Feed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/properties?sort_by=newest&page=1",
              "host": ["{{base_url}}"],
              "path": ["properties"],
              "query": [
                { "key": "sort_by", "value": "newest" },
                { "key": "category", "value": "", "disabled": true },
                { "key": "city", "value": "", "disabled": true },
                { "key": "min_price", "value": "", "disabled": true },
                { "key": "max_price", "value": "", "disabled": true },
                { "key": "page", "value": "1" }
              ]
            },
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Search Properties",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/properties/search?keyword=villa&city=Casablanca&min_price=500000&max_price=2000000&sort_by=price_asc",
              "host": ["{{base_url}}"],
              "path": ["properties", "search"],
              "query": [
                { "key": "keyword", "value": "villa" },
                { "key": "city", "value": "Casablanca" },
                { "key": "min_price", "value": "500000" },
                { "key": "max_price", "value": "2000000" },
                { "key": "min_size", "value": "", "disabled": true },
                { "key": "max_size", "value": "", "disabled": true },
                { "key": "rooms_count", "value": "", "disabled": true },
                { "key": "min_completion_score", "value": "", "disabled": true },
                { "key": "sort_by", "value": "price_asc" }
              ]
            },
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Property Detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/properties/1",
            "header": [{ "key": "Accept", "value": "application/json" }]
          }
        },
        {
          "name": "Create Property (Draft)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/properties",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 1,\n  \"title\": \"Bel appartement F3 - Hay Riad\",\n  \"description\": \"Appartement moderne de 90m² bien situé.\",\n  \"price\": 850000,\n  \"city\": \"Rabat\",\n  \"address\": \"Hay Riad, Rue 10\",\n  \"field_values\": {\n    \"1\": \"90\",\n    \"2\": \"3\",\n    \"3\": \"1\",\n    \"4\": \"3\",\n    \"5\": \"6\",\n    \"6\": \"5\",\n    \"7\": \"Bon état\",\n    \"8\": \"Nord\",\n    \"9\": \"true\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/properties/1",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 800000,\n  \"description\": \"Description mise à jour.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Publish Property",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/properties/1/publish",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Mark as Sold",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/properties/1/sold",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Toggle Archive",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/properties/1/toggle-archive",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/properties/1",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Property Media",
      "item": [
        {
          "name": "Upload Media to Slot",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/properties/1/media",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "slot_id", "value": "1", "type": "text" },
                { "key": "file", "type": "file", "src": "" },
                { "key": "is_cover", "value": "true", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Delete Media",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/properties/1/media/1",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Saved Properties",
      "item": [
        {
          "name": "My Saved Listings",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/saved",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Toggle Save (Save or Unsave)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/saved/1/toggle",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Check if Saved",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/saved/1/check",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "My Inbox",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/conversations",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Start Conversation",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/conversations",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"property_id\": 1,\n  \"message\": \"Bonjour, est-ce que la propriété est toujours disponible?\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Conversation",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/conversations/1",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/conversations/1/messages",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/conversations/1/messages",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"Oui, la propriété est disponible. Voulez-vous la visiter?\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Mark Messages as Read",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/conversations/1/messages/read",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "My Notifications",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Unread Count (Navbar Badge)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/notifications/unread-count",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Mark One as Read",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/notifications/1/read",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/notifications/read-all",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
